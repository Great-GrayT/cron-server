// Prisma schema — single source of truth for the database.
// `prisma migrate` turns these models into version-controlled SQL migrations;
// the generated client emits parameterised queries (SQL-injection safe), which
// neutralises any injection vectors hiding in untrusted RSS/scraped strings.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pg_trgm powers fast substring / word-inside-text search (ILIKE '%word%')
  // on the indexed text columns below.
  extensions = [pg_trgm]
}

/// A processed job posting (ported from the old R2 `JobStatistic` shape).
/// This is the queryable backbone for the stats/rss APIs: indexed columns
/// support time-series (extractedDate), filtering (industry/seniority/country),
/// and search (title/company). Array fields hold the multi-value tags.
model Job {
  id            String   @id @default(uuid()) @db.Uuid
  // One global row per posting (deduped by url). Per-user ownership lives in the
  // UserJob link table. The stable metadata hash lives in `extId`.
  extId         String?  @map("ext_id")
  url           String   @unique
  title         String
  company       String
  location      String
  country       String?
  city          String?
  region        String? // Europe | America | Middle East | Asia | Africa | Oceania
  postedDate    DateTime @map("posted_date")
  extractedDate DateTime @map("extracted_date")

  industry  String
  seniority String

  // Heavy description text lives in the slim JobDescription side table (own
  // trigram index, 6-month TTL) so this hot fact table stays narrow. Recreatable
  // from the R2 cold archive. null relation = description pruned / never stored.
  descriptionRow JobDescription?

  keywords         String[]
  certificates     String[]
  software         String[]
  programmingSkills String[] @map("programming_skills")
  academicDegrees  String[] @map("academic_degrees")
  // Numeric so it supports range filtering (e.g. 2..5 years). Parsed + capped
  // (<=15) at ingest from the raw "N years" text.
  experienceYears  Int?     @map("experience_years")
  roleType         String?  @map("role_type")
  roleCategory     String?  @map("role_category")

  // Flattened SalaryData (was a nested object in R2).
  salaryMin      Float?  @map("salary_min")
  salaryMax      Float?  @map("salary_max")
  salaryCurrency String? @map("salary_currency")
  salaryPeriod   String? @map("salary_period")

  sourceFeed String?  @map("source_feed")
  createdAt  DateTime @default(now()) @map("created_at")

  // Denormalized: true if ANY linking UserJob shares the job to public stats.
  // Lets the public stats page filter on a single indexed column (no join).
  sharedToStats Boolean @default(false) @map("shared_to_stats")
  links         UserJob[]

  // --- Scalar filter/sort indexes (one per stats facet + time-series) ---
  @@index([extractedDate])
  @@index([postedDate])
  @@index([industry])
  @@index([seniority])
  @@index([country])
  @@index([region])
  @@index([city])
  @@index([company])
  @@index([roleCategory])
  @@index([roleType])
  @@index([experienceYears])
  @@index([salaryMin])
  @@index([sharedToStats])
  // Time-series-by-category (VelocityStream, CertsBump, heatmaps filtered by facet)
  @@index([extractedDate, industry])
  @@index([extractedDate, seniority])

  // --- Array tag GIN indexes: fast `has`/`hasSome` filtering + unnest
  //     aggregation for SkillsWordCloud / Certs / keyword facets ---
  @@index([keywords], type: Gin)
  @@index([certificates], type: Gin)
  @@index([software], type: Gin)
  @@index([programmingSkills], type: Gin)
  @@index([academicDegrees], type: Gin)

  // --- Trigram GIN indexes: index-fast substring / word-inside-text search
  //     (ILIKE '%word%') for free-text `q` across every text column ---
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "jobs_title_trgm_idx")
  @@index([company(ops: raw("gin_trgm_ops"))], type: Gin, map: "jobs_company_trgm_idx")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "jobs_location_trgm_idx")

  @@map("jobs")
}

/// Slim side table for the heavy job description blob. Split out of `jobs` so the
/// hot fact table (scanned by every stats aggregate) stays narrow. Keeps the
/// description trigram index HERE — and only for the pruning window (old rows are
/// deleted by pruneOldDescriptions), so the index covers a small recent set, not
/// the whole history. Full text is recreatable from the R2 cold archive.
model JobDescription {
  jobId String @id @map("job_id") @db.Uuid
  text  String @db.Text
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Word-inside-text search (ILIKE '%q%') for the stats `q` free-text facet.
  @@index([text(ops: raw("gin_trgm_ops"))], type: Gin, map: "job_descriptions_text_trgm_idx")
  @@map("job_descriptions")
}

/// Progress record for an async R2 backfill run. The admin route creates one,
/// launches the import detached, and returns the id immediately; the browser
/// polls this row for live status/logs (no long-held request -> no gateway 502).
model BackfillJob {
  id         String    @id @default(uuid()) @db.Uuid
  status     String    @default("running") // running | done | failed
  phase      String    @default("starting") // human-readable current step
  monthsDone Int       @default(0) @map("months_done")
  daysDone   Int       @default(0) @map("days_done")
  read       Int       @default(0)
  inserted   Int       @default(0)
  // Rolling tail of log lines ({ level, message, ts }) for the admin monitor.
  logs       Json      @default("[]")
  error      String?
  ownerId    String    @map("owner_id") @db.Uuid
  startedAt  DateTime  @default(now()) @map("started_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  finishedAt DateTime? @map("finished_at")

  @@index([status, startedAt])
  @@map("backfill_jobs")
}

/// Links a user (and the feed it came from) to a shared Job row. Per-user
/// ownership + share-to-stats flag now live here, so one posting is stored once.
model UserJob {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  jobId        String   @map("job_id") @db.Uuid
  feedId       String?  @map("feed_id") @db.Uuid
  shareToStats Boolean  @default(true) @map("share_to_stats")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  feed         Feed?    @relation(fields: [feedId], references: [id], onDelete: SetNull)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("user_jobs")
}

/// Dedup ledger for the Telegram pipelines (replaces the R2 UrlCache).
/// One row per URL we've already sent, namespaced per pipeline, with an
/// expiry so old postings can re-notify after the window.
model SentUrl {
  id        String   @id @default(uuid()) @db.Uuid
  namespace String // "url-rss" | "url-rss-aryan" | "url-scraper"
  url       String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([namespace, url])
  @@index([namespace, expiresAt])
  @@map("sent_urls")
}

/// A registered account. Owns feeds, channels, GOAT config, and schedules.
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  /// Optional unique handle; can be used to log in instead of email.
  username     String?  @unique
  /// scrypt hash; null for OAuth-only accounts.
  passwordHash String?  @map("password_hash")
  name         String?
  role         String   @default("user") // user | admin

  // Extended profile.
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  phoneDialCode  String? @map("phone_dial_code")
  phoneNumber    String? @map("phone_number")
  mobileDialCode String? @map("mobile_dial_code")
  mobileNumber   String? @map("mobile_number")
  speciality     String?
  country        String?
  city           String?

  /// Email ownership confirmed via the verification link. Login is blocked until
  /// true; unverified accounts older than 7 days are purged by the cron tick.
  emailVerified Boolean  @default(false) @map("email_verified")

  // Profile picture: avatarUrl = Google/external URL; avatarData = uploaded
  // base64 data URL (stored in-DB per product decision).
  avatarUrl  String? @map("avatar_url")
  avatarData String? @map("avatar_data") @db.Text

  // Page keys this user is banned from (admin-managed). e.g. ["stats","applied"].
  revokedPages String[] @map("revoked_pages")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts         OAuthAccount[]
  feeds            Feed[]
  channels         NotificationChannel[]
  filterSets       FilterSet[]
  schedules        Schedule[]
  userJobs         UserJob[]
  appliedJobs      AppliedJob[]
  authTokens       AuthToken[]
  messagesSent     Message[] @relation("MessagesSent")
  messagesReceived Message[] @relation("MessagesReceived")

  @@map("users")
}

/// Direct messages: user -> admin (toAdmin=true, toUserId null) or user -> user
/// (toUserId set). Replies are just new rows in the other direction.
model Message {
  id         String    @id @default(uuid()) @db.Uuid
  fromUserId String    @map("from_user_id") @db.Uuid
  toUserId   String?   @map("to_user_id") @db.Uuid
  toAdmin    Boolean   @default(false) @map("to_admin")
  subject    String?
  body       String    @db.Text
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  from       User      @relation("MessagesSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  to         User?     @relation("MessagesReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, createdAt])
  @@index([fromUserId, createdAt])
  @@index([toAdmin, createdAt])
  @@map("messages")
}

/// Single-use, hashed tokens for email verification + password reset.
model AuthToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "email_verify" | "password_reset"
  tokenHash String   @map("token_hash") // sha256 of the raw token sent by email
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, type])
  @@index([tokenHash])
  @@map("auth_tokens")
}

/// A job the user marked as applied by clicking the signed "Apply here" tracking
/// link in their Telegram. Per-user (replaces the old default/aryan R2 stores).
model AppliedJob {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId      String    @map("job_id") // md5(url) hash from the tracking link
  jobUrl     String    @map("job_url")
  title      String
  company    String
  location   String
  city       String?
  country    String?
  region     String?
  postedDate DateTime? @map("posted_date")
  roleType   String?   @map("role_type")
  industry   String?
  appliedAt  DateTime  @default(now()) @map("applied_at")

  // One row per (user, job): clicking the same link again just updates the time.
  @@unique([userId, jobId])
  @@index([userId, appliedAt])
  @@map("applied_jobs")
}

/// Linked OAuth identity (google | github) for an account.
model OAuthAccount {
  id             String @id @default(uuid()) @db.Uuid
  userId         String @map("user_id") @db.Uuid
  provider       String // google | github
  providerUserId String @map("provider_user_id")
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

/// A user's RSS feed. `notify` = push matches to their Telegram; `shareToStats`
/// = contribute its jobs to the public stats page ("stat rss" vs "personal rss").
model Feed {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  url          String
  name         String?
  notify       Boolean  @default(true)
  shareToStats Boolean  @default(false) @map("share_to_stats")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  // Last test/send outcome — drives the status dot. null = never run.
  lastStatus   String?   @map("last_status") // "success" | "fail"
  lastTestedAt DateTime? @map("last_tested_at")
  lastError    String?   @map("last_error")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userJobs     UserJob[]

  @@unique([userId, url])
  @@index([active])
  @@index([shareToStats])
  @@map("feeds")
}

/// A user's Telegram destination. `kind` = main | goat. Bot token AES-GCM encrypted.
model NotificationChannel {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  kind         String   // main | goat
  botTokenEnc  String   @map("bot_token_enc")
  chatId       String   @map("chat_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  // Last connection-test outcome — drives the status dot. null = never tested.
  lastStatus   String?   @map("last_status") // "success" | "fail"
  lastTestedAt DateTime? @map("last_tested_at")
  lastError    String?   @map("last_error")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@map("notification_channels")
}

/// Per-user GOAT filter rules (was hardcoded constants in job-monitor).
/// A saved JFS (Job Filtering System) filter set. A user has many; a job that
/// matches ANY enabled set is posted to the user's "filtered" Telegram channel.
model FilterSet {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  name       String
  enabled    Boolean           @default(true)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  conditions FilterCondition[]

  @@index([userId])
  @@map("filter_sets")
}

/// One condition in a set. Conditions are evaluated left-to-right; `connector`
/// joins THIS condition to the next one ("AND" | "OR"); the last is ignored.
model FilterCondition {
  id          String    @id @default(uuid()) @db.Uuid
  filterSetId String    @map("filter_set_id") @db.Uuid
  position    Int
  /// industry | seniority | roleCategory | roleType | keyword | certificate |
  /// software | programming | country | region | company | experience | salary | title
  field       String
  op          String    @default("is") // is | has | contains | gte | lte
  value       String
  connector   String    @default("AND") // AND | OR — joins to the NEXT condition
  filterSet   FilterSet @relation(fields: [filterSetId], references: [id], onDelete: Cascade)

  @@index([filterSetId, position])
  @@map("filter_conditions")
}

/// A user's schedule for one pipeline. The /api/cron/tick endpoint runs the
/// ones whose interval has elapsed since lastRunAt.
model Schedule {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  job              String    // check-jobs | stats-ingest | scrape
  intervalMinutes  Int       @default(60) @map("interval_minutes")
  // Optional 5-field cron ("m h dom mon dow"); when set it overrides interval.
  cronExpr         String?   @map("cron_expr")
  enabled          Boolean   @default(true)
  lastRunAt        DateTime? @map("last_run_at")
  // optional params for the scrape job
  scrapeSearch     String?   @map("scrape_search")
  scrapeCountries  String?   @map("scrape_countries")
  scrapeTimeFilter Int?      @map("scrape_time_filter")
  // Last run outcome — drives the status dot. null = never run.
  lastStatus       String?   @map("last_status") // "success" | "fail"
  lastError        String?   @map("last_error")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs             ScheduleRun[]

  @@unique([userId, job])
  @@index([enabled])
  @@map("schedules")
}

/// History of schedule executions (manual "run now" + cron ticks).
model ScheduleRun {
  id         String   @id @default(uuid()) @db.Uuid
  scheduleId String   @map("schedule_id") @db.Uuid
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id") @db.Uuid
  job        String
  ok         Boolean  @default(false)
  summary    String? // human-readable result (JSON-ish)
  error      String?
  durationMs Int      @default(0) @map("duration_ms")
  trigger    String   @default("manual") // manual | cron
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([scheduleId, createdAt])
  @@map("schedule_runs")
}

/// One row per cron/scrape execution — structured run history for tracing.
model CronRun {
  id        String   @id @default(uuid()) @db.Uuid
  traceId   String   @map("trace_id")
  job       String // "check-jobs" | "check-jobs-aryan" | "scrape-jobs" | "stats-ingest"
  ok        Boolean  @default(false)
  total     Int      @default(0)
  newItems  Int      @default(0) @map("new_items")
  sent      Int      @default(0)
  failed    Int      @default(0)
  durationMs Int     @default(0) @map("duration_ms")
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([job, createdAt])
  @@map("cron_runs")
}

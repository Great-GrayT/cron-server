# ─────────────────────────────────────────────────────────────
# Public template. NO SECRETS. Copy to `.env` and fill real values.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection consumed by Prisma (src/db/client.ts).
DATABASE_URL="postgresql://user:password@localhost:5432/jobs_cron"

# Shared secret guarding the cron endpoints. The external cron service must send
# it as `Authorization: Bearer <token>`. If unset, requests are allowed only in
# development (fail-closed in production).
CRON_SECRET="change-me-long-random-string"

# --- Main RSS → Telegram pipeline (/api/cron/check-jobs) ---
RSS_FEED_URLS="https://rss.app/feeds/xxxx.xml,https://rss.app/feeds/yyyy.xml"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
GOAT_TELEGRAM_BOT_TOKEN=""
GOAT_TELEGRAM_CHAT_ID=""
CHECK_INTERVAL_MINUTES="60"

# --- Aryan pipeline (/api/cron/check-jobs-aryan) ---
RSS_ARYAN_FEED_URLS=""
TELEGRAM_ARYAN_BOT_TOKEN=""
TELEGRAM_ARYAN_CHAT_ID=""
GOAT_TELEGRAM_ARYAN_BOT_TOKEN=""
GOAT_TELEGRAM_ARYAN_CHAT_ID=""

# --- Stats ingestion (/api/stats/get) ---
RSS_STATS_FEED_URLS=""

# --- Apply-tracking links embedded in Telegram messages ---
APP_BASE_URL="http://localhost:3000"
TRACKING_SECRET="change-me"

# --- CORS: comma-separated origins allowed to call this API.
#     Empty = reflect the request origin (dev). Set explicitly in production. ---
CORS_ALLOW_ORIGINS=""

# --- Edge rate limit (middleware) ---
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="60"

# Logger verbosity: debug | info | warn | error
LOG_LEVEL="info"

# PostgreSQL connection consumed by Prisma (src/db/client.ts).
DATABASE_URL="postgresql://user:password@localhost:5432/jobs_cron"

# Shared secret guarding the cron endpoints. The external cron service must send
# it as `Authorization: Bearer <token>`. If unset, requests are allowed only in
# development (fail-closed in production).
CRON_SECRET="435621b3844c006b39057c701e1a36332b34a3f9a531c80b9045e56ab8f4f469"

# ── Multi-tenant auth/secrets (server-wide, NOT per user) ────────────────────
# JWT signing secret for account sessions.
JWT_SECRET="42bff99d1ccdb894e56c77bcf19766d77e45f19a329ccd69f983a245a9d2db28"
# 32-byte key (64 hex chars) that encrypts per-user Telegram tokens at rest.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="a48b4aacbc8570fe55ed3e19c7b64548c1463d96d5cf875ec70a0b935c95dd15"
# Where to bounce the browser after OAuth login (your frontend origin).
FRONTEND_URL="http://localhost:3000"
# Public base URL of THIS server (used to build OAuth callback URLs).
OAUTH_REDIRECT_BASE="http://localhost:3000"
# OAuth providers (leave blank to disable that provider).
